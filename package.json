{
    "name": "@pangtou-addon/your-addon",
    "version": "0.1.5",
    "private": true,
    "type": "module",
    "files": [
        "README.md",
        "manifest.json",
        "frontend.config.json",
        "frontend.json",
        "index.html",
        "package.json",
        "scripts",
        "tsconfig.json",
        "vite.config.ts",
        "src",
        "types"
    ],
    "scripts": {
        "manifest:sync": "node ./scripts/manifest-sync.mjs",
        "dev": "pnpm run manifest:sync && vite",
        "build": "pnpm run manifest:sync && vite build",
        "preview": "pnpm run manifest:sync && vite preview --host 0.0.0.0 --port 4179 --strictPort",
        "check:types": "pnpm run manifest:sync && vue-tsc --noEmit -p tsconfig.json",
        "manifest:check": "node ./scripts/manifest-check.mjs",
        "sync:sdk-version": "node ./scripts/sync-sdk-version.mjs",
        "pack": "node ./scripts/pack.mjs",
        "dev:remote:build": "vite build --watch",
        "dev:remote:serve": "vite preview --port 4179 --strictPort"
    },
    "dependencies": {
        "@pangtou/host-sdk": "0.1.5",
        "@pangtou/module-runtime": "0.1.5",
        "@pangtou/shared": "0.1.5",
        "vue": "^3.5.29"
    },
    "devDependencies": {
        "@originjs/vite-plugin-federation": "^1.4.1",
        "@vitejs/plugin-vue": "^6.0.4",
        "sass": "^1.99.0",
        "typescript": "^5.8.3",
        "vite": "^7.3.2",
        "vue-tsc": "^3.1.0"
    },
    "description": "用于演示模块插件脚手架的最小实现。"
}
