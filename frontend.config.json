{
    "enabled": true,
    "runtime": "federation",
    "routeBase": "/your-plugin",
    "meta": {
        "icon": "Grid",
        "order": 100,
        "preload": false
    },
    "entry": {
        "federation": {
            "remote": "your_plugin_remote",
            "entry": "http://localhost:4179/assets/remoteEntry.js",
            "expose": "./module"
        }
    },
    "capabilities": {
        "pages": true,
        "widgets": false,
        "settings": false
    },
    "compatibility": {
        "console": ">=0.1.2"
    }
}
