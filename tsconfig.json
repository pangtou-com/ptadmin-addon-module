{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "types": ["vite/client"]
    },
    "include": ["src/**/*.ts", "src/**/*.vue", "types/**/*.d.ts"]
}
